@model WorkSphereHRMS.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container mt-4">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-person-badge-fill"></i>
                Employee Details
            </h3>
        </div>

        <div class="card-body">

            <!-- Employee Photo -->
            <div class="text-center mb-4">

                @if (!string.IsNullOrEmpty(Model.ProfileImage))
                {
                    <img src="~/uploads/@Model.ProfileImage"
                         class="rounded-circle shadow border"
                         width="180"
                         height="180"
                         style="object-fit:cover;" />
                }
                else
                {
                    <img src="https://ui-avatars.com/api/?name=@Model.FirstName+@Model.LastName&background=0D6EFD&color=fff&size=180"
                         class="rounded-circle shadow border"
                         width="180"
                         height="180" />
                }

                <h3 class="mt-3 mb-1">
                    @Model.FirstName @Model.LastName
                </h3>

                <span class="badge bg-info fs-6">
                    @Model.Designation
                </span>

            </div>

            <hr />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <strong>Employee Code</strong>
                    <p class="mb-0">@Model.EmployeeCode</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Email</strong>
                    <p class="mb-0">@Model.Email</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Phone</strong>
                    <p class="mb-0">@Model.Phone</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Gender</strong>
                    <p class="mb-0">@Model.Gender</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Date of Birth</strong>
                    <p class="mb-0">@Model.DateOfBirth.ToString("dd MMM yyyy")</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Joining Date</strong>
                    <p class="mb-0">@Model.JoiningDate.ToString("dd MMM yyyy")</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Department</strong>
                    <p class="mb-0">@Model.Department?.DepartmentName</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Role</strong>
                    <p class="mb-0">@Model.Role?.RoleName</p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Salary</strong>
                    <p class="mb-0 text-success fw-bold">
                        ₹ @Model.Salary.ToString("N2")
                    </p>
                </div>

                <div class="col-md-6 mb-3">
                    <strong>Status</strong><br />

                    @if (Model.Status == "Active")
                    {
                        <span class="badge bg-success">
                            Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inactive
                        </span>
                    }

                </div>

                <div class="col-12 mb-3">
                    <strong>Address</strong>
                    <p class="mb-0">@Model.Address</p>
                </div>

            </div>

        </div>

        <div class="card-footer text-end">

            <a asp-action="Edit"
               asp-route-id="@Model.EmployeeId"
               class="btn btn-warning">

                <i class="bi bi-pencil-square"></i>
                Edit

            </a>

            <a asp-action="Index"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Back

            </a>

        </div>

    </div>

</div>