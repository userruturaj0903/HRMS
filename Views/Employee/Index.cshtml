@model IEnumerable<WorkSphereHRMS.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container-fluid mt-4">

    <div class="card shadow border-0">

        <div class="card-header bg-white">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h3 class="fw-bold mb-1">
                        <i class="bi bi-people-fill text-primary"></i>
                        Employees
                    </h3>

                    <small class="text-muted">
                        Manage all employees |
                        Total Employees :
                        <strong>@Model.Count()</strong>
                    </small>
                </div>

                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add Employee
                </a>

            </div>

        </div>

        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-6">

                    <form asp-action="Index" method="get">

                        <div class="input-group">

                            <input type="text"
                                   name="searchString"
                                   value="@Context.Request.Query["searchString"]"
                                   class="form-control"
                                   placeholder="Search by Name, Email or Employee Code..." />

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i>
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Reset
                            </a>

                        </div>

                    </form>

                </div>

            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Employee</th>
                            <th>Code</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            @foreach (var employee in Model)
                            {
                                <tr>

                                    <td>

                                        <div class="d-flex align-items-center">

                                            @if (!string.IsNullOrEmpty(employee.ProfileImage))
                                            {
                                                <img src="~/uploads/@employee.ProfileImage"
                                                     class="rounded-circle me-3"
                                                     width="50"
                                                     height="50"
                                                     style="object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <img src="https://ui-avatars.com/api/?name=@employee.FirstName+@employee.LastName&background=0D6EFD&color=fff"
                                                     class="rounded-circle me-3"
                                                     width="50"
                                                     height="50" />
                                            }

                                            <div>

                                                <div class="fw-bold">
                                                    @employee.FirstName @employee.LastName
                                                </div>

                                                <small class="text-muted">
                                                    @employee.Phone
                                                </small>

                                            </div>

                                        </div>

                                    </td>

                                    <td>
                                        <span class="badge bg-primary">
                                            @employee.EmployeeCode
                                        </span>
                                    </td>

                                    <td>@employee.Email</td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @employee.Department?.DepartmentName
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @employee.Role?.RoleName
                                        </span>
                                    </td>

                                    <td>

                                        @if (employee.Status == "Active")
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Inactive
                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Details"
                                           asp-route-id="@employee.EmployeeId"
                                           class="btn btn-info btn-sm"
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@employee.EmployeeId"
                                           class="btn btn-warning btn-sm"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@employee.EmployeeId"
                                           class="btn btn-danger btn-sm"
                                           title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7" class="text-center py-5">

                                    <i class="bi bi-people display-4 text-secondary"></i>

                                    <h5 class="mt-3">
                                        No Employees Found
                                    </h5>

                                    <p class="text-muted">
                                        Click the <strong>Add Employee</strong> button to create your first employee.
                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>