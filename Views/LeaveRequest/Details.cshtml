@model WorkSphereHRMS.Models.LeaveRequest

@{
    ViewData["Title"] = "Leave Request Details";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow border-0">

            <div class="card-header bg-info text-white">

                <h4 class="mb-0">
                    <i class="bi bi-eye"></i>
                    Leave Request Details
                </h4>

            </div>

            <div class="card-body">

                <table class="table table-bordered align-middle">

                    <tr>
                        <th width="30%">Employee</th>
                        <td>
                            @Model.Employee?.FirstName
                            @Model.Employee?.LastName
                        </td>
                    </tr>

                    <tr>
                        <th>Leave Type</th>
                        <td>
                            @Model.LeaveType?.LeaveTypeName
                        </td>
                    </tr>

                    <tr>
                        <th>From Date</th>
                        <td>
                            @Model.FromDate.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <th>To Date</th>
                        <td>
                            @Model.ToDate.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <th>Total Days</th>
                        <td>
                            @((Model.ToDate - Model.FromDate).Days + 1)
                        </td>
                    </tr>

                    <tr>
                        <th>Reason</th>
                        <td>
                            @Model.Reason
                        </td>
                    </tr>

                    <tr>
                        <th>Status</th>
                        <td>

                            @if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success fs-6">
                                    Approved
                                </span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger fs-6">
                                    Rejected
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark fs-6">
                                    Pending
                                </span>
                            }

                        </td>
                    </tr>

                    <tr>
                        <th>Applied Date</th>
                        <td>
                            @Model.AppliedDate.ToString("dd-MMM-yyyy hh:mm tt")
                        </td>
                    </tr>

                </table>

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>
                        Back

                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.LeaveRequestId"
                       class="btn btn-warning">

                        <i class="bi bi-pencil"></i>
                        Edit

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>