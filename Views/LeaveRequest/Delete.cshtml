@model WorkSphereHRMS.Models.LeaveRequest

@{
    ViewData["Title"] = "Delete Leave Request";
}

<div class="row justify-content-center">

    <div class="col-lg-7">

        <div class="card shadow border-danger">

            <div class="card-header bg-danger text-white">

                <h4 class="mb-0">
                    <i class="bi bi-trash"></i>
                    Delete Leave Request
                </h4>

            </div>

            <div class="card-body">

                <div class="alert alert-warning">

                    <i class="bi bi-exclamation-triangle-fill"></i>

                    <strong>Are you sure you want to delete this leave request?</strong>

                </div>

                <table class="table table-bordered align-middle">

                    <tr>
                        <th width="30%">Employee</th>
                        <td>
                            @Model.Employee?.FirstName
                            @Model.Employee?.LastName
                        </td>
                    </tr>

                    <tr>
                        <th>Leave Type</th>
                        <td>
                            @Model.LeaveType?.LeaveTypeName
                        </td>
                    </tr>

                    <tr>
                        <th>From Date</th>
                        <td>
                            @Model.FromDate.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <th>To Date</th>
                        <td>
                            @Model.ToDate.ToString("dd-MMM-yyyy")
                        </td>
                    </tr>

                    <tr>
                        <th>Total Days</th>
                        <td>
                            @((Model.ToDate - Model.FromDate).Days + 1)
                        </td>
                    </tr>

                    <tr>
                        <th>Status</th>
                        <td>

                            @if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success">
                                    Approved
                                </span>
                            }
                            else if (Model.Status == "Rejected")
                            {
                                <span class="badge bg-danger">
                                    Rejected
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            }

                        </td>
                    </tr>

                    <tr>
                        <th>Reason</th>
                        <td>
                            @Model.Reason
                        </td>
                    </tr>

                </table>

                <form asp-action="Delete">

                    <input type="hidden"
                           asp-for="LeaveRequestId" />

                    <div class="d-flex justify-content-between">

                        <a asp-action="Index"
                           class="btn btn-secondary">

                            <i class="bi bi-arrow-left"></i>
                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-danger">

                            <i class="bi bi-trash"></i>
                            Delete

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>