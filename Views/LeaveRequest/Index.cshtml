@model IEnumerable<WorkSphereHRMS.Models.LeaveRequest>

@{
    ViewData["Title"] = "Leave Management";
}

<div class="card shadow border-0">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h2 class="fw-bold mb-1">
                    <i class="bi bi-calendar2-check text-primary"></i>
                    Leave Management
                </h2>

                <p class="text-muted mb-0">
                    Manage Employee Leave Requests |
                    Total Requests :
                    <strong>@Model.Count()</strong>
                </p>

            </div>

            <a asp-action="Create" class="btn btn-primary">

                <i class="bi bi-plus-circle"></i>

                Apply Leave

            </a>

        </div>

    </div>

    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">

                @TempData["Success"]

                <button class="btn-close" data-bs-dismiss="alert"></button>

            </div>
        }

        <form method="get">

            <div class="input-group mb-4">

                <input type="text"
                       class="form-control"
                       name="searchString"
                       value="@Context.Request.Query["searchString"]"
                       placeholder="Search Employee Name..." />

                <button class="btn btn-primary">

                    <i class="bi bi-search"></i>

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Reset

                </a>

            </div>

        </form>

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var totalDays = (item.ToDate - item.FromDate).Days + 1;

                            <tr>

                                <td>

                                    <strong>

                                        @item.Employee?.FirstName
                                        @item.Employee?.LastName

                                    </strong>

                                </td>

                                <td>

                                    @item.LeaveType?.LeaveTypeName

                                </td>

                                <td>

                                    @item.FromDate.ToString("dd-MMM-yyyy")

                                </td>

                                <td>

                                    @item.ToDate.ToString("dd-MMM-yyyy")

                                </td>

                                <td>

                                    @totalDays

                                </td>

                                <td>

                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Pending
                                        </span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="badge bg-success">
                                            Approved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Rejected
                                        </span>
                                    }

                                </td>

                                <td class="text-center">

                                    <a asp-action="Details"
                                       asp-route-id="@item.LeaveRequestId"
                                       class="btn btn-info btn-sm">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.LeaveRequestId"
                                       class="btn btn-warning btn-sm">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.LeaveRequestId"
                                       class="btn btn-danger btn-sm">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                    @if(item.Status=="Pending")
                                    {
                                        <a asp-action="Approve"
                                           asp-route-id="@item.LeaveRequestId"
                                           class="btn btn-success btn-sm">

                                            <i class="bi bi-check-lg"></i>

                                        </a>

                                        <a asp-action="Reject"
                                           asp-route-id="@item.LeaveRequestId"
                                           class="btn btn-secondary btn-sm">

                                            <i class="bi bi-x-lg"></i>

                                        </a>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="7" class="text-center py-5">

                                <i class="bi bi-calendar-x display-4 text-secondary"></i>

                                <h5 class="mt-3">

                                    No Leave Requests Found

                                </h5>

                                <p class="text-muted">

                                    Click <strong>Apply Leave</strong> to create a leave request.

                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>