 @model IEnumerable<WorkSphereHRMS.Models.Attendance>

@{
    ViewData["Title"] = "Attendance Report";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                <i class="fas fa-calendar-check"></i>
                Attendance Report
            </h4>

            <button class="btn btn-light" onclick="window.print()">
                <i class="fas fa-print"></i> Print
            </button>

        </div>

        <div class="card-body">

            <!-- Filter -->

            <form asp-action="AttendanceReport" method="get" class="row g-3 mb-4">

                <div class="col-md-4">

                    <label class="form-label fw-bold">From Date</label>

                    <input type="date"
                           name="fromDate"
                           class="form-control"
                           value="@Context.Request.Query["fromDate"]" />

                </div>

                <div class="col-md-4">

                    <label class="form-label fw-bold">To Date</label>

                    <input type="date"
                           name="toDate"
                           class="form-control"
                           value="@Context.Request.Query["toDate"]" />

                </div>

                <div class="col-md-4 d-flex align-items-end">

                    <button type="submit" class="btn btn-success me-2">
                        <i class="fas fa-search"></i> Filter
                    </button>

                    <a asp-action="AttendanceReport" class="btn btn-secondary">
                        Reset
                    </a>

                </div>

            </form>

            <!-- Table -->

            <table class="table table-bordered table-hover table-striped">

                <thead class="table-dark">

                    <tr>

                        <th>Employee</th>
                        <th>Date</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Status</th>
                        <th>Remarks</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.Employee?.FirstName @item.Employee?.LastName
                                </td>

                                <td>
                                    @item.AttendanceDate.ToString("dd-MMM-yyyy")
                                </td>

                                <td>
                                    @(item.CheckIn?.ToString(@"hh\:mm") ?? "-")
                                </td>

                                <td>
                                    @(item.CheckOut?.ToString(@"hh\:mm") ?? "-")
                                </td>

                                <td>

                                    @if (item.Status == "Present")
                                    {
                                        <span class="badge bg-success">
                                            Present
                                        </span>
                                    }
                                    else if (item.Status == "Absent")
                                    {
                                        <span class="badge bg-danger">
                                            Absent
                                        </span>
                                    }
                                    else if (item.Status == "Late")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Late
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            @item.Status
                                        </span>
                                    }

                                </td>

                                <td>
                                    @item.Remarks
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6" class="text-center text-danger">
                                No attendance records found.
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts
{
<script>

window.onbeforeprint = function () {

    document.querySelector("form").style.display = "none";

};

window.onafterprint = function () {

    document.querySelector("form").style.display = "block";

};

</script>
}