@using WorkSphereHRMS.Models

@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";

    var attendance = ViewBag.TodayAttendance as Attendance;
}

<div class="container-fluid">

    <h2 class="mb-4">
        <i class="fas fa-home text-primary"></i>
        Welcome, @User.Identity?.Name
    </h2>

    <!-- Dashboard Cards -->

    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <i class="fas fa-calendar-check fa-3x text-success"></i>

                    <h5 class="mt-3">Present Days</h5>

                    <h2 class="text-success">--</h2>

                    <small class="text-muted">Current Month</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <i class="fas fa-file-signature fa-3x text-warning"></i>

                    <h5 class="mt-3">Leave Balance</h5>

                    <h2 class="text-warning">--</h2>

                    <small class="text-muted">Available Leaves</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <i class="fas fa-indian-rupee-sign fa-3x text-primary"></i>

                    <h5 class="mt-3">This Month Salary</h5>

                    <h2 class="text-primary">--</h2>

                    <small class="text-muted">Net Salary</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <i class="fas fa-umbrella-beach fa-3x text-danger"></i>

                    <h5 class="mt-3">Upcoming Holidays</h5>

                    <h2 class="text-danger">--</h2>

                    <small class="text-muted">Current Month</small>
                </div>
            </div>
        </div>

    </div>

    <!-- Today's Attendance -->

    <div class="row mb-4">

        <div class="col-lg-12">

            <div class="card shadow">

                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-clock"></i>
                        Today's Attendance
                    </h5>
                </div>

                <div class="card-body text-center">

                    @if (attendance == null)
                    {
                        <h5 class="text-danger mb-3">
                            You have not checked in today.
                        </h5>

                        <form asp-action="CheckIn" method="post">
                            <button class="btn btn-success btn-lg">
                                <i class="fas fa-sign-in-alt"></i>
                                Check In
                            </button>
                        </form>
                    }
                    else if (attendance.CheckOut == null)
                    {
                        <div class="alert alert-success">

                            <h5>Checked In Successfully</h5>

                            <p>
                                <strong>Check In Time :</strong>
                                @attendance.CheckIn
                            </p>

                        </div>

                        <form asp-action="CheckOut" method="post">
                            <button class="btn btn-danger btn-lg">
                                <i class="fas fa-sign-out-alt"></i>
                                Check Out
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-primary">

                            <h5>Attendance Completed</h5>

                            <p>
                                <strong>Check In :</strong>
                                @attendance.CheckIn
                            </p>

                            <p>
                                <strong>Check Out :</strong>
                                @attendance.CheckOut
                            </p>

                            <p>
                                <strong>Status :</strong>
                                @attendance.Status
                            </p>

                            <button class="btn btn-success" disabled>
                                Attendance Completed
                            </button>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <!-- Employee Information -->

    <div class="row">

        <div class="col-lg-12">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Employee Information</h5>
                </div>

                <div class="card-body">

                    <table class="table table-bordered">

                        <tr>
                            <th width="25%">Username</th>
                            <td>@User.Identity?.Name</td>
                        </tr>

                        <tr>
                            <th>Department</th>
                            <td>--</td>
                        </tr>

                        <tr>
                            <th>Designation</th>
                            <td>--</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>--</td>
                        </tr>

                        <tr>
                            <th>Mobile</th>
                            <td>--</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>