@model WorkSphereHRMS.Models.CompanySettings

@{
    ViewData["Title"] = "Company Settings";
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                <i class="fas fa-cogs"></i>
                Company Settings
            </h4>

            <a asp-action="Edit" class="btn btn-light">
                <i class="fas fa-edit"></i>
                Edit
            </a>

        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-3 text-center">

                    @if (!string.IsNullOrEmpty(Model.CompanyLogo))
                    {
                        <img src="~/CompanyLogo/@Model.CompanyLogo"
                             class="img-thumbnail"
                             style="width:180px;height:180px;" />
                    }
                    else
                    {
                        <img src="~/images/no-logo.png"
                             class="img-thumbnail"
                             style="width:180px;height:180px;" />
                    }

                </div>

                <div class="col-md-9">

                    <table class="table table-bordered table-striped">

                        <tr>
                            <th width="30%">Company Name</th>
                            <td>@Model.CompanyName</td>
                        </tr>

                        <tr>
                            <th>Address</th>
                            <td>@Model.Address</td>
                        </tr>

                        <tr>
                            <th>City</th>
                            <td>@Model.City</td>
                        </tr>

                        <tr>
                            <th>State</th>
                            <td>@Model.State</td>
                        </tr>

                        <tr>
                            <th>Country</th>
                            <td>@Model.Country</td>
                        </tr>

                        <tr>
                            <th>Pin Code</th>
                            <td>@Model.PinCode</td>
                        </tr>

                        <tr>
                            <th>Phone</th>
                            <td>@Model.Phone</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Website</th>
                            <td>@Model.Website</td>
                        </tr>

                        <tr>
                            <th>Financial Year</th>
                            <td>@Model.FinancialYear</td>
                        </tr>

                        <tr>
                            <th>Office Timing</th>
                            <td>
                                @Model.OfficeStart - @Model.OfficeEnd
                            </td>
                        </tr>

                        <tr>
                            <th>Grace Minutes</th>
                            <td>@Model.GraceMinutes Minutes</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>