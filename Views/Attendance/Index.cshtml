@model IEnumerable<WorkSphereHRMS.Models.Attendance>

@{
    ViewData["Title"] = "Attendance";
}

<div class="card shadow border-0">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-calendar-check text-primary"></i>
                    Attendance
                </h2>

                <p class="text-muted mb-0">
                    Manage employee attendance |
                    Total Records :
                    <strong>@Model.Count()</strong>
                </p>
            </div>

            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Mark Attendance
            </a>

        </div>

    </div>

    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">

                @TempData["Success"]

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>
        }

        <form method="get">

            <div class="input-group mb-4">

                <input type="text"
                       class="form-control"
                       name="searchString"
                       placeholder="Search Employee Name..." />

                <button class="btn btn-primary">

                    <i class="bi bi-search"></i>

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Reset

                </a>

            </div>

        </form>

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Employee</th>
                        <th>Date</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Status</th>
                        <th>Remarks</th>
                        <th class="text-center">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>

                                    <strong>
                                        @item.Employee?.FirstName
                                        @item.Employee?.LastName
                                    </strong>

                                </td>

                                <td>

                                    @item.AttendanceDate.ToString("dd-MMM-yyyy")

                                </td>

                                <td>

                                    @(item.CheckIn?.ToString(@"hh\:mm") ?? "-")

                                </td>

                                <td>

                                    @(item.CheckOut?.ToString(@"hh\:mm") ?? "-")

                                </td>

                                <td>

                                    @if (item.Status == "Present")
                                    {
                                        <span class="badge bg-success">
                                            Present
                                        </span>
                                    }
                                    else if (item.Status == "Absent")
                                    {
                                        <span class="badge bg-danger">
                                            Absent
                                        </span>
                                    }
                                    else if (item.Status == "Leave")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Leave
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">
                                            @item.Status
                                        </span>
                                    }

                                </td>

                                <td>

                                    @(string.IsNullOrEmpty(item.Remarks) ? "-" : item.Remarks)

                                </td>

                                <td class="text-center">

                                    <a asp-action="Details"
                                       asp-route-id="@item.AttendanceId"
                                       class="btn btn-info btn-sm">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.AttendanceId"
                                       class="btn btn-warning btn-sm">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.AttendanceId"
                                       class="btn btn-danger btn-sm">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="7" class="text-center py-5">

                                <i class="bi bi-calendar-x display-4 text-secondary"></i>

                                <h5 class="mt-3">
                                    No Attendance Records Found
                                </h5>

                                <p class="text-muted">
                                    Click <strong>Mark Attendance</strong> to add attendance.
                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>