@model WorkSphereHRMS.Models.Attendance

@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="row justify-content-center">

    <div class="col-md-6">

        <div class="card shadow border-danger">

            <div class="card-header bg-danger text-white">

                <h4 class="mb-0">

                    <i class="bi bi-trash"></i>

                    Delete Attendance

                </h4>

            </div>

            <div class="card-body">

                <div class="alert alert-warning">

                    Are you sure you want to delete this attendance record?

                </div>

                <table class="table">

                    <tr>
                        <th>Employee</th>
                        <td>@Model.Employee?.FirstName @Model.Employee?.LastName</td>
                    </tr>

                    <tr>
                        <th>Date</th>
                        <td>@Model.AttendanceDate.ToString("dd-MMM-yyyy")</td>
                    </tr>

                    <tr>
                        <th>Status</th>
                        <td>@Model.Status</td>
                    </tr>

                </table>

                <form asp-action="Delete">

                    <input type="hidden"
                           asp-for="AttendanceId" />

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Cancel

                    </a>

                    <button type="submit"
                            class="btn btn-danger">

                        <i class="bi bi-trash"></i>

                        Delete

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>