<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkSphere HRMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkSphereHRMS.styles.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        html,
        body {
            height: 100%;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }

        main {
            flex: 1;
        }

        footer {
            margin-top: auto;
        }

    </style>

</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">
                <i class="bi bi-buildings"></i>
                WorkSphere HRMS
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Department"
                               asp-action="Index">
                                Departments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Employee"
                               asp-action="Index">
                                Employees
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Attendance"
                               asp-action="Index">
                                Attendance
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Leave"
                               asp-action="Index">
                                Leave
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item me-3">

                            <span class="text-white">
                                <i class="bi bi-person-circle"></i>
                                Welcome,
                                <strong>@User.Identity.Name</strong>
                            </span>

                        </li>

                        <li class="nav-item">

                            <a class="btn btn-danger btn-sm"
                               asp-controller="Account"
                               asp-action="Logout">

                                <i class="bi bi-box-arrow-right"></i>
                                Logout

                            </a>

                        </li>

                    </ul>

                }

            </div>

        </div>

    </nav>

    <!-- Main Content -->

    <main class="container mt-4">

        @RenderBody()

    </main>

    <!-- Footer -->

    <footer class="bg-dark text-white py-3">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-md-6 text-center text-md-start">

                    <small>

                        © @DateTime.Now.Year WorkSphere HRMS.
                        All Rights Reserved.

                    </small>

                </div>

                <div class="col-md-6 text-center text-md-end">

                    <small>

                        Developed with
                        <span class="text-danger">❤</span>
                        using ASP.NET Core MVC & Bootstrap 5

                    </small>

                </div>

            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>