<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - WorkSphere HRMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorkSphereHRMS.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        html,
        body {
            height: 100%;
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f4f6f9;
        }

        body {
            overflow-x: hidden;
        }

        /* ==========================
              NAVBAR
        ========================== */

        .top-navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 60px;
            background: #0d6efd;
            z-index: 1050;
        }

        .top-navbar .navbar-brand {
            font-size: 24px;
            font-weight: 600;
        }

        /* ==========================
              SIDEBAR
        ========================== */

        .sidebar {

            position: fixed;
            top: 60px;
            left: 0;
            width: 230px;
            height: calc(100vh - 60px);

            background: #212529;

            transition: .3s;

            overflow-y: auto;

        }

        .sidebar a {

            display: flex;
            align-items: center;

            color: #ced4da;

            text-decoration: none;

            padding: 14px 22px;

            transition: .2s;

        }

        .sidebar a i {

            width: 24px;
            margin-right: 10px;

        }

        .sidebar a:hover,
        .sidebar a.active {

            background: #0d6efd;
            color: #fff;

        }

        /* ==========================
              CONTENT
        ========================== */

        .content {

            margin-top: 60px;
            margin-left: 230px;

            padding: 30px;

            min-height: calc(100vh - 120px);

        }

        /* ==========================
              FOOTER
        ========================== */

        footer {

            margin-left: 230px;

        }

        /* ==========================
              MENU BUTTON
        ========================== */

        #menuBtn {

            display: none;

        }

        /* ==========================
             MOBILE
        ========================== */

        @@media (max-width: 768px) {

            #menuBtn {

                display: inline-block;

            }

            .sidebar {

                left: -230px;

            }

            .sidebar.show {

                left: 0;

            }

            .content {

                margin-left: 0;
                padding: 20px;

            }

            footer {

                margin-left: 0;

            }

        }

    </style>

</head>
<body>

    <!-- ==========================
           TOP NAVBAR
    =========================== -->

    <nav class="navbar navbar-expand-lg navbar-dark top-navbar shadow">

        <div class="container-fluid">

            <!-- Mobile Menu Button -->

            <button class="btn btn-light me-3"
                    id="menuBtn">

                <i class="bi bi-list fs-5"></i>

            </button>

            <!-- Logo -->

            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-buildings"></i>

                WorkSphere HRMS

            </a>

            <!-- Right Side -->

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="ms-auto d-flex align-items-center">

                    <span class="text-white me-3 d-none d-md-inline">

                        <i class="bi bi-person-circle"></i>

                        Welcome,

                        <strong>@User.Identity.Name</strong>

                    </span>

                    <a asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-danger btn-sm">

                        <i class="bi bi-box-arrow-right"></i>

                        Logout

                    </a>

                </div>
            }

        </div>

    </nav>


    <!-- ==========================
             SIDEBAR
    =========================== -->

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {

        <div class="sidebar" id="sidebar">

            <a asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-speedometer2"></i>

                Dashboard

            </a>

            <a asp-controller="Department"
               asp-action="Index">

                <i class="bi bi-building"></i>

                Departments

            </a>

            <a asp-controller="Employee"
               asp-action="Index">

                <i class="bi bi-people-fill"></i>

                Employees

            </a>

            <a asp-controller="Attendance"
               asp-action="Index">

                <i class="bi bi-calendar-check"></i>

                Attendance

            </a>

            <a asp-controller="LeaveRequest"
               asp-action="Index">

                <i class="bi bi-calendar-event"></i>

                Leave Management

            </a>

            <hr class="text-secondary">

            <a asp-controller="Payroll"
               asp-action="Index">

                <i class="bi bi-calendar-event"></i>

               Payroll

            </a>

           <a asp-controller="Reports"
               asp-action="Index">

                <i class="bi bi-calendar-event"></i>

               Reports

            </a>
         <a asp-controller="User"
              asp-action="Index">

                <i class="bi bi-calendar-event"></i>

               User Management

            </a>

            <a asp-controller="Settings"
              asp-action="Index">

                <i class="bi bi-calendar-event"></i>

              Settings

            </a>
        </div>

    }

    <!-- ==========================
            PAGE CONTENT
    =========================== -->

    <main class="content">

        @RenderBody()

    </main>
        <!-- ==========================
            FOOTER
    =========================== -->

    <footer class="bg-white border-top py-3">

        <div class="container-fluid">

            <div class="row align-items-center">

                <div class="col-md-6 text-center text-md-start">

                    <small class="text-muted">

                        © @DateTime.Now.Year <strong>WorkSphere HRMS</strong>.
                        All Rights Reserved.

                    </small>

                </div>

                <div class="col-md-6 text-center text-md-end">

                    <small class="text-muted">

                        Developed with
                        <span class="text-danger">❤</span>
                        using ASP.NET Core MVC & Bootstrap 5

                    </small>

                </div>

            </div>

        </div>

    </footer>

    <!-- ==========================
            JAVASCRIPT
    =========================== -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>

        // Sidebar Toggle

        const menuBtn = document.getElementById("menuBtn");
        const sidebar = document.getElementById("sidebar");

        if (menuBtn && sidebar) {

            menuBtn.addEventListener("click", function () {

                sidebar.classList.toggle("show");

            });

        }

        // Close sidebar when clicking outside (Mobile)

        document.addEventListener("click", function (e) {

            if (window.innerWidth <= 768) {

                if (
                    sidebar &&
                    !sidebar.contains(e.target) &&
                    !menuBtn.contains(e.target)
                ) {
                    sidebar.classList.remove("show");
                }

            }

        });

        // Highlight Active Menu

        const currentUrl = window.location.pathname.toLowerCase();

        document.querySelectorAll(".sidebar a").forEach(function (link) {

            const href = link.getAttribute("href");

            if (href && currentUrl.startsWith(href.toLowerCase())) {

                link.classList.add("active");

            }

        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>