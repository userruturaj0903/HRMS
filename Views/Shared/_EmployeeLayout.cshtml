<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - WorkSphere HRMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>

<body class="bg-light">

    <div class="d-flex">

        <!-- Sidebar -->
        <div class="bg-dark text-white p-3" style="width:260px;min-height:100vh;">

            <h4 class="text-center mb-4">
                <i class="fas fa-user-circle"></i>
                Employee Portal
            </h4>

            <hr />

            <ul class="nav flex-column">

                <li class="nav-item mb-2">
                    <a asp-controller="EmployeeDashboard" asp-action="Index" class="nav-link text-white">
                        <i class="fas fa-house me-2"></i>
                        Dashboard
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="EmployeeProfile" asp-action="Index" class="nav-link text-white">
                        <i class="fas fa-user me-2"></i>
                        My Profile
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a asp-controller="MyAttendance" asp-action="Index" class="nav-link text-white">
                        <i class="fas fa-user me-2"></i>
                        My Attendance
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="EmployeeLeave" asp-action="Create">
                        <i class="fas fa-user me-2"></i> Apply Leave
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-controller="EmployeeLeave" asp-action="Index">
                        <i class="fas fa-user me-2"></i> Leave History
                    </a>
                </li>

                

                <li class="nav-item mb-2">
                    <a asp-controller="EmployeePayroll" asp-action="Index" class="nav-link text-white">
                        <i class="fas fa-money-check-dollar me-2"></i>
                        My Payroll
                    </a>
                </li>

               

                <li class="nav-item mb-2">
                    <a asp-controller="EmployeeAccount" asp-action="ChangePassword" class="nav-link text-white">
                        <i class="fas fa-key me-2"></i>
                        Change Password
                    </a>
                </li>

                <li class="nav-item mt-4">
                    <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                        <i class="fas fa-right-from-bracket me-2"></i>
                        Logout
                    </a>
                </li>

            </ul>

        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">

            <!-- Top Navbar -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">

                <div class="container-fluid">

                    <h5 class="mb-0">
                        Employee Dashboard
                    </h5>

                    <div class="ms-auto">

                        <span class="me-3">
                            <i class="fas fa-user-circle"></i>
                            Welcome,
                            <strong>@User.Identity?.Name</strong>
                        </span>

                        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger btn-sm">
                            Logout
                        </a>

                    </div>

                </div>

            </nav>

            <!-- Page Body -->
            <div class="container-fluid p-4">

                @RenderBody()

            </div>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>