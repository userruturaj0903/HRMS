@model IEnumerable<WorkSphereHRMS.Models.Attendance>

@{
    ViewData["Title"] = "My Attendance";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container-fluid">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="fas fa-calendar-check text-success me-2"></i>
                My Attendance
            </h2>
            <p class="text-muted mb-0">
                View your attendance records.
            </p>
        </div>

        <div>
            <input type="month" class="form-control" />
        </div>
    </div>

    <!-- Attendance Card -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">Attendance History</h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Attendance Date</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Status</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.AttendanceDate.ToString("dd-MMM-yyyy")
                                    </td>

                                    <td>
                                        @(item.CheckIn.HasValue
                                            ? item.CheckIn.Value.ToString(@"hh\:mm")
                                            : "-")
                                    </td>

                                    <td>
                                        @(item.CheckOut.HasValue
                                            ? item.CheckOut.Value.ToString(@"hh\:mm")
                                            : "-")
                                    </td>

                                    <td>

                                        @{
                                            var status = item.Status ?? "";
                                        }

                                        @switch (status)
                                        {
                                            case "Present":
                                                <span class="badge bg-success">Present</span>
                                                break;

                                            case "Absent":
                                                <span class="badge bg-danger">Absent</span>
                                                break;

                                            case "Leave":
                                                <span class="badge bg-warning text-dark">Leave</span>
                                                break;

                                            default:
                                                <span class="badge bg-secondary">
                                                    @(string.IsNullOrWhiteSpace(status) ? "-" : status)
                                                </span>
                                                break;
                                        }

                                    </td>

                                    <td>
                                        @(string.IsNullOrWhiteSpace(item.Remarks)
                                            ? "-"
                                            : item.Remarks)
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="5" class="text-center py-5">

                                    <i class="fas fa-calendar-times fa-3x text-secondary mb-3"></i>

                                    <h5 class="mt-3">
                                        No Attendance Records Found
                                    </h5>

                                    <p class="text-muted mb-0">
                                        No attendance records are available.
                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>