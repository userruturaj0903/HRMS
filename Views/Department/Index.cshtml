@model IEnumerable<WorkSphereHRMS.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="container-fluid mt-4">

    <div class="card shadow border-0">

        <div class="card-header bg-white">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>

                    <h3 class="fw-bold mb-1">
                        <i class="bi bi-building text-primary"></i>
                        Departments
                    </h3>

                    <small class="text-muted">
                        Manage all departments |
                        Total Departments :
                        <strong>@Model.Count()</strong>
                    </small>

                </div>

                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i>
                    Add Department
                </a>

            </div>

        </div>

        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-6">

                    <form asp-action="Index" method="get">

                        <div class="input-group">

                            <input type="text"
                                   name="searchString"
                                   value="@Context.Request.Query["searchString"]"
                                   class="form-control"
                                   placeholder="Search Department..." />

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i>
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Reset
                            </a>

                        </div>

                    </form>

                </div>

            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th width="80">ID</th>
                            <th>Department</th>
                            <th class="text-center" width="180">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            @foreach (var department in Model)
                            {
                                <tr>

                                    <td>

                                        <span class="badge bg-primary">
                                            @department.DepartmentId
                                        </span>

                                    </td>

                                    <td>

                                        <div class="d-flex align-items-center">

                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                                                 style="width:45px;height:45px;">

                                                <i class="bi bi-building fs-5"></i>

                                            </div>

                                            <div>

                                                <div class="fw-bold">
                                                    @department.DepartmentName
                                                </div>

                                                <small class="text-muted">
                                                    Department
                                                </small>

                                            </div>

                                        </div>

                                    </td>

                                    <td class="text-center">

                                        <a asp-action="Edit"
                                           asp-route-id="@department.DepartmentId"
                                           class="btn btn-warning btn-sm"
                                           title="Edit">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@department.DepartmentId"
                                           class="btn btn-danger btn-sm"
                                           title="Delete">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="3" class="text-center py-5">

                                    <i class="bi bi-building display-4 text-secondary"></i>

                                    <h5 class="mt-3">
                                        No Departments Found
                                    </h5>

                                    <p class="text-muted">
                                        Click the <strong>Add Department</strong> button to create your first department.
                                    </p>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>