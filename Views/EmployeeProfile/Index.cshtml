@model WorkSphereHRMS.Models.Employee

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="container-fluid">

    <div class="row mb-4">

        <div class="col-md-12">
            <h2>
                <i class="fas fa-user-circle text-primary"></i>
                My Profile
            </h2>
            <hr />
        </div>

    </div>

    <div class="row">

        <!-- Profile Image -->
        <div class="col-lg-3">

            <div class="card shadow">

                <div class="card-body text-center">

                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="~/uploads/@Model.ProfileImage"
                             class="img-fluid rounded-circle border"
                             style="width:180px;height:180px;object-fit:cover;" />
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@Model.FirstName+@Model.LastName&background=0D6EFD&color=fff&size=180"
                             class="img-fluid rounded-circle border"
                             style="width:180px;height:180px;object-fit:cover;" />
                    }

                    <h4 class="mt-3">
                        @Model.FirstName @Model.LastName
                    </h4>

                    <p class="text-muted mb-1">
                        @Model.Designation
                    </p>

                    <span class="badge bg-success">
                        @Model.Status
                    </span>

                </div>

            </div>

        </div>

        <!-- Employee Details -->
        <div class="col-lg-9">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        Employee Information
                    </h5>
                </div>

                <div class="card-body">

                    <table class="table table-bordered table-striped">

                        <tr>
                            <th width="30%">Employee Code</th>
                            <td>@Model.EmployeeCode</td>
                        </tr>

                        <tr>
                            <th>First Name</th>
                            <td>@Model.FirstName</td>
                        </tr>

                        <tr>
                            <th>Last Name</th>
                            <td>@Model.LastName</td>
                        </tr>

                        <tr>
                            <th>Username</th>
                            <td>@Model.Username</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Phone</th>
                            <td>@Model.Phone</td>
                        </tr>

                        <tr>
                            <th>Gender</th>
                            <td>@Model.Gender</td>
                        </tr>

                        <tr>
                            <th>Date of Birth</th>
                            <td>@Model.DateOfBirth.ToString("dd MMM yyyy")</td>
                        </tr>

                        <tr>
                            <th>Joining Date</th>
                            <td>@Model.JoiningDate.ToString("dd MMM yyyy")</td>
                        </tr>

                        <tr>
                            <th>Department</th>
                            <td>@Model.Department?.DepartmentName</td>
                        </tr>

                        <tr>
                            <th>Role</th>
                            <td>@Model.Role?.RoleName</td>
                        </tr>

                        <tr>
                            <th>Designation</th>
                            <td>@Model.Designation</td>
                        </tr>

                        <tr>
                            <th>Salary</th>
                            <td>₹ @Model.Salary.ToString("N2")</td>
                        </tr>

                        <tr>
                            <th>Address</th>
                            <td>@Model.Address</td>
                        </tr>

                        <tr>
                            <th>Account Status</th>
                            <td>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                        </tr>

                    </table>

                </div>

                <div class="card-footer text-end">

                    <a asp-controller="EmployeeProfile"
                       asp-action="Edit"
                       class="btn btn-primary">
                        <i class="fas fa-edit"></i>
                        Edit Profile
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>