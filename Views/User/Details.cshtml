@model WorkSphereHRMS.Models.User

@{
    ViewData["Title"] = "User Details";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h4>
                <i class="fas fa-user"></i>
                User Details
            </h4>
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <tr>
                    <th width="30%">Username</th>
                    <td>@Model.Username</td>
                </tr>

                <tr>
                    <th>Email</th>
                    <td>@Model.Email</td>
                </tr>

                <tr>
                    <th>Password</th>
                    <td>@Model.Password</td>
                </tr>

                <tr>
                    <th>Role</th>
                    <td>
                        @if (Model.Role == "Admin")
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else if (Model.Role == "HR")
                        {
                            <span class="badge bg-primary">HR</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Employee</span>
                        }
                    </td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                </tr>

                <tr>
                    <th>Created Date</th>
                    <td>@Model.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                </tr>

            </table>

            <div class="mt-3">

                <a asp-action="Edit"
                   asp-route-id="@Model.UserId"
                   class="btn btn-warning">
                    <i class="fas fa-edit"></i> Edit
                </a>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Back to List
                </a>

            </div>

        </div>

    </div>

</div>