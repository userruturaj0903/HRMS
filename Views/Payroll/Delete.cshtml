@model WorkSphereHRMS.Models.Payroll

@{
    ViewData["Title"] = "Delete Payroll";
}

<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-danger text-white">
            <h4>
                <i class="fas fa-trash"></i>
                Delete Payroll
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <h5>Are you sure you want to delete this payroll record?</h5>
            </div>

            <table class="table table-bordered">

                <tr>
                    <th width="30%">Employee</th>
                    <td>@Model.Employee?.FirstName @Model.Employee?.LastName</td>
                </tr>

                <tr>
                    <th>Month</th>
                    <td>@Model.Month</td>
                </tr>

                <tr>
                    <th>Year</th>
                    <td>@Model.Year</td>
                </tr>

                <tr>
                    <th>Basic Salary</th>
                    <td>₹ @Model.BasicSalary.ToString("N2")</td>
                </tr>

                <tr>
                    <th>Net Salary</th>
                    <td class="fw-bold text-success">
                        ₹ @Model.NetSalary.ToString("N2")
                    </td>
                </tr>

                <tr>
                    <th>Payment Date</th>
                    <td>@Model.PaymentDate.ToString("dd-MMM-yyyy")</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>

                        @if (Model.Status == "Paid")
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Unpaid</span>
                        }

                    </td>
                </tr>

            </table>

            <form asp-action="Delete">

                <input type="hidden" asp-for="PayrollId" />

                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i>
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>